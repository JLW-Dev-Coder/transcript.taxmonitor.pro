{
  "auth": {
    "required": false,
    "trustClientIdentityFields": false,
    "type": "none"
  },
  "contract": {
    "authority": [
      "R2_TTMP_CANONICAL"
    ],
    "governs": "TTMP magic link request flow",
    "path": "/contracts/sign-in.contract.json",
    "source": "Transcript Tax Monitor",
    "title": "Transcript Tax Monitor — Sign In Contract",
    "usedOnPages": [
      "/sign-in.html"
    ],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/api/transcripts/magic-link/request",
    "method": "POST",
    "receiptKeyPattern": "receipts/ttmp/auth/magic-links/{eventId}.json",
    "receiptSource": "ttmp_magic_link_request"
  },
  "effects": {
    "eventIdFrom": "payload.eventId",
    "receiptAppend": {
      "to": "receipts/ttmp/auth/magic-links/{eventId}.json"
    },
    "writeOrder": [
      "receiptAppend"
    ],
    "writes": [
      "auth_requests"
    ]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "email": {
        "format": "email",
        "type": "string"
      },
      "eventId": {
        "minLength": 1,
        "type": "string"
      },
      "redirect": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "email",
      "eventId",
      "redirect"
    ],
    "type": "object"
  },
  "response": {
    "error": {
      "error": "magic_link_request_failed",
      "ok": false
    },
    "success": {
      "eventId": "{payload.eventId}",
      "ok": true,
      "status": "sent"
    }
  },
  "schema": {
    "name": "ttmp_sign_in_magic_link_request",
    "version": 1
  }
}
